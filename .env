# Replace <db_password> with your actual MongoDB Atlas password.
# Replace firstdb with the database name you want to use and firstcollection with your collection name.
# To use Atlas, uncomment and set the correct URI below:
# MONGO_URI="mongodb+srv://ContactForm:YOUR_PASSWORD@cluster0.x8wyfwb.mongodb.net/firstdb?retryWrites=true&w=majority"

# If you do not have Atlas set up yet, the app will use local MongoDB at:
# mongodb://127.0.0.1:27017/firstdb